#!/usr/bin/env fish
# Usage: gls [-o] <query> [group]

argparse 'o/out' -- $argv
or exit 1

set -l query $argv[1]
set -l group (if set -q argv[2]; echo $argv[2]; else; echo $GITLAB_GROUP_ID; end)

if test -z "$query" -o -z "$group"
    echo "Usage: "(status filename)" [-o] <query> [group_path_or_id]"
    echo "  Or: set -x GITLAB_GROUP_ID my-org"
    echo "  -o, --out  Write matched repo names to search_results.out"
    exit 1
end

echo "🔍  query : $query"
echo "📁  group : $group"
echo ""

# glab api handles auth from ~/.config/glab-cli/config.yml automatically.
# --paginate follows Link headers so all pages are fetched.
# jq processes each page (JSON array) and extracts project_id per line.
set -l project_ids (
    glab api "groups/$group/search?scope=blobs&search=$query&per_page=100" \
        --paginate \
    | jq -r '.[].project_id' \
    | sort -u
)

if test (count $project_ids) -eq 0
    echo "No matches found."
    exit 0
end

echo "Repos with matches:"
echo "────────────────────────────────────"

set -l out_file "search_results.out"

if set -q _flag_out
    printf "" > $out_file
end

for pid in $project_ids
    set -l name (glab api "projects/$pid" | jq -r '.path_with_namespace')
    echo "  - $name"
    if set -q _flag_out
        echo $name >> $out_file
    end
end

echo ""
echo "✅  "(count $project_ids)" repo(s) matched"

if set -q _flag_out
    echo "📄  Results written to $out_file"
end

